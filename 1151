import java.util.*

fun main(args: Array<String>) {

    val input = readLine()
    if (input != null) {
        val n = input.toInt()
        
        var a = 0
        var b = 1
   
        val resultado = mutableListOf<Int>()

        for (i in 0 until n) {
            resultado.add(a)
            
            val proximo = a + b
            a = b
            b = proximo
        }
        println(resultado.joinToString(" "))
    }
}
